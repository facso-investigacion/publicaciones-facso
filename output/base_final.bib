@article{GALAZVALDERRAMA2025,
  author        = {Galaz Valderrama, Caterine Joanna},
  title         = {RETHINKING ACCESSIBILITY FROM FEMINIST EPISTEMOLOGIES},
  year          = {2025},
  journal       = {Psicologia e Sociedade},
  abstract      = {Feminist epistemologies problematize the role of scientific knowledge in the reproduction of patriarchal logic. Similarly, emancipatory and inclusive research promotes scientific knowledge committed in the transforming ableism and disabilityism. This work combines both approaches to critically reflect on narrative research with people involved in disability activism in Chile. The study was based on the logic of “accessibility adjustment”, which proved insufficient and problematic. Through various fieldwork scenes, we argue for the need to shift from “adjustment” to the feminist notion of “articulation”. We conclude that any process of articulation between researcher and researched, not just those that include disability, implies the mobilization of elements that make the encounter possible, and that the transformations that occur are bidirectional, far from being a mere “adjustment” due to disability.},
  author_keywords = {Ableism; Accessibility; Disability Studies; Feminist Epistemology; Qualitative Research},
