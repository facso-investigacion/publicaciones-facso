}
@incollection{ANDRADEGUZMN2024,
  author        = {Andrade Guzmán, Carlos Alejandro},
  title         = {Social Work Education: Prospects in Teaching Programmes in Chile},
  year          = {2024},
  booktitle     = {The Routledge International Handbook of Social Work Teaching},
  abstract      = {This chapter examines the current state of social work education in Chile, focusing on five interconnected issues that have shaped the field: neoliberal democracy and public policies, the development of social work, teaching prospects, increased inequality and exclusion, and intervention with social movements, immigration, and ethnic identities. Drawing on a range of sources, including academic research, policy documents, and practitioner perspectives, we explore the challenges and opportunities facing social work educators in Chile, and consider how these might be addressed in the years ahead. Our analysis highlights the need for greater attention to be paid to the theoretical underpinnings of social work practice, and the importance of developing more participatory and inclusive approaches to teaching and learning. We also argue that social work educators must be more proactive in engaging with wider social and political debates, and in advocating for the rights of marginalized and excluded groups. Overall, we suggest that social work education in Chile has historically played a key role in promoting social justice and human rights, but that in the future this will require sustained effort and commitment from all those involved in the field.},
  doi           = {10.4324/9781003422402-9},
  issn          = {104000176},
  affiliation   = {Trabajo social, 12090120 Departamento de Trabajo Social, Universidad de Chile},
  document_type = {Book Chapter},
