@incollection{FERNNDEZDROGUETT2025,
  author        = {Fernández Droguett, Roberto Andrés},
  title         = {Photoethnography as a Research Methodology for Manifestations in Public Space in Times of Revolt},
  year          = {2025},
  booktitle     = {Springer Geography},
  abstract      = {ConsideringMethodology that the public spacePublic space of large cities has been reconfigured by political demonstrationsPolitical demonstrations that not only use it as a stage but also intervene and potentially transform and resignify it, it is a relevant theoretical-methodological challenge today to perfect existing research methods to approach and better understand these phenomena, particularly in current times when various social revolts occur in which the public spacePublic space is the fundamental substrate of them. Based on previous photoethnographyPhotoethnography work on political demonstrationsPolitical demonstrations, in this paper, we propose to present some foundations of this methodologyMethodology and its application to the field of demonstrations in public spacePublic space with their effects on the city and the territory. For this, we will explain the techniques and problems associated with the production of photoethnographic data, and then present the procedures for analysis and presentation of results. First, we will distinguish between the representative dimension of photographyPhotography and its performative dimension, and how this distinction invites us to assume and problematize both the authorial and contextual conditions of photographyPhotography and its ethical–political consequences. Then, we will propose that photoethnographic fieldwork involves a situated deployment of the researcher, who must seek different photographs in terms of planes, distances, actors, actions, and contexts. Finally, we will argue that the presentation of results should seek to articulate the photographs with the ethnographic text in order to preserve and highlight the constitutive importance of the image for phenomena such as the political occupation of public spacePublic space.},
  author_keywords = {Photoethnography; Political demonstrations; Public space; Qualitative research methodologies},
  keywords      = {Photoethnography; Political demonstrations; Public space; Qualitative research methodologies},
