@article{TIJOUXMERINO2025a,
  author        = {Tijoux Merino, María Emilia},
  title         = {JOURNALISTIC DISCOURSE AND CROSS-BORDER MOBILITY: THE FIGURE OF THE ARGENTINE IMMIGRANT IN THE CHILEAN NATIONAL PRESS},
  year          = {2025},
  journal       = {SI SOMOS AMERICANOS-REVISTA DE ESTUDIOS TRANSFRONTERIZOS},
  abstract      = {The aim is to identify references to the figure of the Argentine immigrant in the recent discourse of the Chilean national press and analyze them in light of the imaginary component of cross-border mobility between Argentina and Chile. A Critical Discourse Analysis (CDA) was applied to references to the Argentine immigrant published by the newspapers El Mercurio and La Tercera in 2022-2023. The results reveal a marginal presence of figure of the Argentine immigrant in these discourses. On the rare occasions when it is mentioned, it is represented positively or neutrally, portraying the Argentine immigrant as something more than a cross-border migrant, dissociating them from crime and irregularity, characterizing them as infrequent, and detaching Argentina from the Andean-cross-border. Additionally, Argentina and Chile are framed as allies in the fight against transnational crime and victims of a shared cross-border enemy, embodied by Peru. It is concluded that both the dominant imaginary of Chilean national identity and its alterity, as well as the social memory of crossborder mobility between Argentina and Chile, inform the discursive practices employed by the Chilean national press when referring to Argentine immigrants, fostering a specific framing of the information.},
  author_keywords = {Argentina; Chile; cross-border mobility; immigrant; journalistic discourse},
  keywords      = {Argentina; Chile; cross-border mobility; immigrant; journalistic discourse},
  doi           = {10.61303/07190948.v25i.1228},
  issn          = {0718-2910},
  language      = {Multi-idioma},
  affiliation   = {Sociología, 12090119 Dpto. de Sociología (funcionamiento), Universidad de Chile},
  document_type = {Article},
  source        = {Scopus},
  note          = {Cited By: 0}
}
@article{MORALESMORGADO2025,
  author        = {Morales Morgado, Héctor Freddy},
  title         = {SEWING AND MODERNITY IN THE ATACAMA DESERT: THE SEWING MACHINE AS A CATALYST FOR DOMESTIC TRANSFORMATION (1879-1960)},
  year          = {2025},
  journal       = {SI SOMOS AMERICANOS-REVISTA DE ESTUDIOS TRANSFRONTERIZOS},
  abstract      = {This article explores the role of the domestic sewing machine as an agent of sociocultural transformation in the Atacama Desert between 1879 and 1960. Through a historical and ethnographic methodology, it analyzes how this technical artifact reconfigured sewing practices and gender relations in mining and Indigenous communities in northern Chile. The sewing machine not only facilitated the adaptation of clothing to extreme environmental conditions but also enabled the incorporation of new textile technologies, technical knowledge, and forms of domestic labor. It is argued that the widespread use of the sewing machine and clothing contributed to the consolidation of new distinctions of gender, class, and ethnicity.},
  author_keywords = {Atacama Desert; clothing; gender relations; sewing machine; technology},
