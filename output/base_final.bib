@article{CADENASRAMOS2025,
  author        = {Cadenas Ramos, Hugo Rodrigo},
  title         = {Society/nature: Enactive perspectives for social systems theory},
  year          = {2025},
  journal       = {CURRENT SOCIOLOGY},
  abstract      = {This article examines the society/nature distinction within sociological and anthropological discourse, particularly concerning Luhmann’s social systems theory. The increasing urgency surrounding climate change and the complexities of the Anthropocene has necessitated reconsidering this dichotomy, often seen as reinforcing sociocentrism. Social systems theory’s emphasis on the system/environment distinction has overlooked the importance of the environment, relegating it to a mere backdrop for societal functioning. By engaging with three critical perspectives – Ontological Relativism, Transcendent Connectionism, and Circular Cosmologism – we emphasize both the contributions and shortcomings of social systems theory in this regard. We then propose a synthesis of these insights through a systemic enactive approach, suggesting that its theoretical framework can enhance our understanding of the society/nature distinction within social systems theory. Ultimately, this article aims to open new research avenues that address the intricate relationship between social systems and their natural environments. Cet article aborde la distinction entre société et nature du point de vue de la théorie des systèmes sociaux. L’hypothèse directrice de cette recherche est que la distinction entre société et nature peut être abordée comme une distinction entre système et environnement, mais qu’une telle opération nécessite de surmonter d’importants obstacles théoriques. Les approches dites énactives sont explorées afin de surmonter ces lacunes et développer dans ces domaines de nouvelles voies de recherche, qui peuvent être alimentées par de nouvelles approches conceptuelles et apporter en même temps de nouvelles perspectives aux débats actuels sur les problèmes environnementaux et technologiques du XXIe siècle. Este artículo examina la distinción sociedad/naturaleza en debates sociológicos y antropológicos actuales, particularmente en relación con la teoría de los sistemas sociales de Luhmann. La creciente urgencia que rodea al cambio climático y las complejidades del Antropoceno han hecho necesario reconsiderar esta dicotomía, que a menudo se considera que refuerza el sociocentrismo. El énfasis de la teoría de los sistemas sociales en la distinción sistema/entorno ha pasado por alto la importancia del entorno, relegándolo a un mero telón de fondo para el funcionamiento de la sociedad. En este contexto, se abordan tres perspectivas críticas -el relativismo ontológico, el conexionismo trascendental y el cosmologismo circular-, destacando tanto sus aportaciones como deficiencias frente a la teoría de los sistemas sociales. Se propone una síntesis de estos puntos de vista a través de un enfoque sistémico enactivo (SEA), sugiriendo que su marco teórico puede mejorar nuestra comprensión de la distinción sociedad/naturaleza dentro de la teoría de los sistemas sociales. En última instancia, este artículo pretende abrir nuevas vías de investigación que aborden la intrincada relación entre los sistemas sociales y sus entornos naturales.},
  author_keywords = {Guiding distinctions; social systems theory; society/nature; system/environment; systemic enactive approach},
  keywords      = {Guiding distinctions; social systems theory; society/nature; system/environment; systemic enactive approach},
  doi           = {10.1177/00113921251332200},
  issn          = {0011-3921},
  language      = {Inglés},
  affiliation   = {Trabajo social, 12090120 Departamento de Trabajo Social, Universidad de Chile},
  document_type = {Article},
  source        = {Scopus},
  note          = {Cited By: 1}
}
@article{PREZAHUMADA2023c,
  author        = {Pérez Ahumada, Pablo Alonso},
  title         = {Trade union strength, business power, and labor policy reform: The cases of Argentina and Chile in comparative perspective},
  year          = {2023},
  journal       = {INTERNATIONAL JOURNAL OF COMPARATIVE SOCIOLOGY},
  abstract      = {In this article, I explain why pro-labor reforms succeed or fail. Focusing on the cases of Argentina and Chile, I show that labor reforms are more successful in extending trade union rights when unions successfully build associational power and employers are less able to do so. Consistent with this argument, a quantitative analysis of time-series cross-sectional data from 78 countries suggests that the level of class power disparity is negatively correlated with the extension of workers’ collective rights. At the end of the article, I discuss how these results have implications for the study of labor reforms and power resources.},
  author_keywords = {Employer associations; labor reforms; labor rights; Latin America; power resources; trade unions},
