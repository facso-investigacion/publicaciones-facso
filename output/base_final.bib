  author        = {Castillo Valenzuela, Juan Carlos},
  title         = {Perception of economic inequality: concepts, associated factors and prospects of a burgeoning research agenda (Percepcion de desigualdad economica: conceptos, factores asociados y proyecciones de una agenda creciente de investigacion)},
