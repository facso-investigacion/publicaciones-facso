@incollection{SCHWARTZMAN2025a,
  author        = {Schwartzman, Mahia Saracostti},
  title         = {Educational Alliances for Climate Action: Analysis of Partnerships Between Universities and Schools in Education for Sustainability},
  year          = {2025},
  booktitle     = {Lecture Notes in Networks and Systems},
  abstract      = {This review explores the dynamic partnerships between universities and schools in fostering climate action and sustainability education. It highlights the critical role of scientific literacy in environmental awareness and the transformative impact of educational collaborations in enhancing students’ engagement with climate action. Utilizing a scoping review methodology, the study systematically analyzes literature from databases. Search terms include combinations of “university-school partnership,” “educational collaboration,” “climate action,” “sustainability education,” “community engagement,” and “environmental awareness.” The review maps out key findings, methodologies, and approaches utilized in existing studies, aiming to understand how these partnerships contribute to sustainability education and climate action. It underscores the need for innovative educational practices and policy implications to cultivate a scientifically informed citizenship ready to tackle environmental challenges. The review sets a foundation for future research directions, emphasizing the importance of multisectoral engagement, internationalization, and the integration of Education for Sustainable Development to advance climate action and sustainability education in a cohesive and impactful manner.},
  author_keywords = {Climate Action; Educational Practices; Scientific Literacy; Sustainability Education; University-School Partnerships},
  keywords      = {Climate Action; Educational Practices; Scientific Literacy; Sustainability Education; University-School Partnerships},
  doi           = {10.1007/978-3-031-78155-1\_8},
