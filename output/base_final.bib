}
@incollection{TIJOUXMERINO2021,
  author        = {Tijoux Merino, María Emilia},
  title         = {The Beautiful Black Girl: Abiayala, Young People, and Movement},
  year          = {2021},
  booktitle     = {Interrogating the Relations between Migration and Education in the South: Migrating Americas},
  abstract      = {This introductory chapter opens with art and Black creative works of Abiayala. La nia negra y el espejo, a poem performed by two Afro-Ecuadorian influencers and written by Afro-Colombian poet Jenny Tenorio, serves as the theoretical framework guiding our analysis. In three parts, the chapter grows the roots that sustain the labor of this collective volume. In the first part, we forefront Abiayala as a means to suspend the coloniality of the 'Americas' in order to engage renewed continental concepts for thinking us beyond the salvific North in migration matters. In part two, we prioritize youth as a liberatory act that frees the discussion of education from its conscripted structures and obsolete processes. A focus on young people breathes life into forms of thinking and imagining educational dynamics infused by youthful forms of life in movement. In part three, we turn to movement to dislodge the notion of migration and instead propose pueblo, pueblear, the practice of being Abiayala. Pueblear articulates the mobilizing intentions in this volume to give life and keep (a)live in movement, the movement of people across space and time.},
