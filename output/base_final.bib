  note          = {Cited By: 5}
}
@incollection{GARRETNMERINO2023,
  author        = {Garretón Merino, Manuel Antonio Eliseo},
  title         = {New Social Movements in Latin America and the Changing Sociopolitical Matrix},
  year          = {2023},
  booktitle     = {The Oxford Handbook of Latin American Social Movements},
  abstract      = {During the 1970s and 1980s, collective action showed several new traits that generated a debate on studying social movements. These are the distance that social movements were having with the political system, the importance of normative claims and non-material demands, the middle-class social composition, and the centrality of identity. Around these characteristics emerged the concept and study of “New Social Movements” (NSMs), and the attempts not only to understand their ways of action, but also the changes in society that could explain their emergence in contraposition to “traditional movements.” In Latin America, the NSMs concept was due to a new political context, mainly explained by the rise of dictatorships and new links that developed between state and society. The latter describes a different cause than that which started the discussion in Europe and North America. During the 1980s, when the debates started in the region, there were no signs of change in the economic or class structure as it seemed to have happened in the First World. Instead, the decomposition of the socio-political matrix and traditional developmentalist state is more relevant to explain the emergence of NSMs in Latin America. Because of the latter, understanding these movements’ nature draws the attention to certain specificities of the societies in which they unfold, and how movements defy them.},
  author_keywords = {Democratization; Identity; Model of modernity; New Social Movements; Non-material demands; Socio-political matrix},
  keywords      = {Democratization; Identity; Model of modernity; New Social Movements; Non-material demands; Socio-political matrix},
  doi           = {10.1093/oxfordhb/9780190870362.013.2},
  issn          = {19087036},
  affiliation   = {Sociología, 12090119 Dpto. de Sociología (funcionamiento), Universidad de Chile},
  document_type = {Book Chapter},
  source        = {Scopus},
  note          = {Cited By: 3}
}
@incollection{MUOZARCE2024,
  author        = {Muñoz Arce, Gianinna Inés},
  title         = {Looking for transformation in social work: Professional resistance as an analytical counterpoint},
  year          = {2024},
  booktitle     = {The Oxford Handbook of Power, Politics, and Social Work},
  abstract      = {According to its international definition, social transformation is a key aspect of social work's political horizons. However, in the context of neoliberal capitalism, managerialist approaches pervading the provision of social services worldwide have set a complex scenario to accomplish such a purpose. The concept of professional resistance offers relevant insights to problematize the position that social workers occupy in frontline interventions, as it opens the possibility for developing more or less explicit actions and/or omissions aiming at challenging the symbolic and material implication of neoliberal agendas in service users' lives. Drawing upon some contributions of critical theorists such as Antonio Gramsci, Michel Foucault, and Gayatri Spivak, professional resistance is conceptually analyzed in this chapter. Counterpoints among these approaches on resistance are discussed in order to provide further insights for social workers' critical practices on the front lines.},
  author_keywords = {Neoliberalism; Professional practice; Resistance; Social transformation; Social work},
  keywords      = {Neoliberalism; Professional practice; Resistance; Social transformation; Social work},
  doi           = {10.1093/oxfordhb/9780197650899.013.46},
