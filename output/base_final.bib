@article{FERNNDEZDROGUETT2023a,
  author        = {Fernández Droguett, Roberto Andrés},
  title         = {School and education in contexts of biological socionatural disasters. a necessary systematic review},
  year          = {2023},
  journal       = {ESTUDIOS PEDAGOGICOS (VALDIVIA)},
  abstract      = {This article is a systematic review following the PRISMA strategy, aiming to identify and analyze empirical studies on schools and education in contexts of socio-natural biological disasters. Searches were conducted in Web of Science, Scopus, ERIC, ScienceDirect, Redalyc, and Dialnet, resulting in a corpus of 43 studies. The research is thematically grouped into four interconnected dimensions: 1) Mental health in biological disaster contexts, 2) Sanitary measures adopted by schools, 3) Digital platforms in biological disasters, and 4) Learning processes in pandemics. These studies are mostly quantitative and focus on school closures, the use of digital platforms, and the teaching figure. It is concluded that there is a need to research with and for educational communities, rescuing their experiences and knowledge to improve population preparedness for future events.},
  author_keywords = {Biological Socio-natural Disasters; desastres socionaturales biológicos; educación; Education; escuela; pandemias; Pandemics; School},
