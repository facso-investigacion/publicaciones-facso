  document_type = {Article},
  source        = {Scopus},
  note          = {Cited By: 5}
}
@article{MORAGAVERGARA2023a,
  author        = {Moraga Vergara, Mauricio Leonardo and Belmar Pantelis, Carolina Andrea},
  title         = {Changes and continuities in subsistence and interaction between marine hunter-gatherer and agro-pottery societies during the late Holocene in the Northern Archipelago, Patagonia, Chile},
  year          = {2023},
  journal       = {LATIN AMERICAN ANTIQUITY},
  abstract      = {Durante el Holoceno tardío en el archipiélago patagónico septentrional (\textasciitilde{}41°30'-47°S), convergerían sistemas culturales diferenciados, interrelacionándose grupos con tradiciones culturales portadoras de cerámica y economías basadas en la producción de alimentos (hortícolas) con grupos de cazadores-recolectores-pescadores marinos presentes desde el Holoceno medio. En este trabajo se evalúa los cambios y continuidades en los patrones de subsistencia y dieta de los grupos que ocuparon este archipiélago a lo largo de su secuencia de ocupación, de acuerdo a los resultados del análisis de los valores de d13C y d15N correspondiente a restos humanos de 27 individuos (\textasciitilde{}4400-150 años cal aP) del Archipiélago de Chiloé (\textasciitilde{}41°30'-43°S), los que son integrados con la información obtenida anteriormente de 36 individuos (\textasciitilde{}2000-300 años cal aP) provenientes del Archipiélago de los Chonos (\textasciitilde{}43°-47°S), así como con muestras complementarias de algas y arqueofauna. A partir de la dieta estimada de 63 individuos, se sugiere una baja intensidad de la interacción de estas trayectorias culturales a lo largo del tiempo en el archipiélago patagónico septentrional con continuidad de los sistemas de caza, pesca y recolección marina. Luego del contacto europeo, se reflejarían los mayores cambios en la subsistencia de estos grupos humanos, especialmente en el Archipiélago de Chiloé.},
  author_keywords = {archipiélago patagónico septentrional; cazadores recolectores marinos; dieta y subsistencia; Holoceno medio/tardío; isótopos estables},
  keywords      = {archipiélago patagónico septentrional; cazadores recolectores marinos; dieta y subsistencia; Holoceno medio/tardío; isótopos estables},
  doi           = {10.1017/laq.2022.38},
  issn          = {1045-6635},
  language      = {Multi-idioma},
  affiliation   = {Antropología, 12090116 Dpto. de Antropología (funcionamiento), Universidad de Chile},
  document_type = {Article},
