  language      = {Español},
  affiliation   = {Trabajo social, Universidad de Chile},
  document_type = {Article},
  source        = {Scopus},
  note          = {Cited By: 1}
}
@article{URIBERODRGUEZ2020,
  author        = {Uribe Rodríguez, Mauricio Iván},
  title         = {Museo, Pukara y chullpas de Nama (Tarapacá, norte de Chile): Diálogos arqueológicos, patrimoniales y políticos entre comuneros andinos e investigadores sociales},
  year          = {2020},
  journal       = {Memorias: Revista digital de historia y arqueologia desde el caribe},
  abstract      = {This work collects the experience developed by a group of researchers in set with an Andean Community in the northern Chile along mutual and fluent relations, those that have spent to lean diverse initiatives like the one of this heritage Project that is born of the interest of the own Community for putting in value and install a circuit of visitation to show the pukara and the chullpas, where the museum constitute a center of interpretation and an office of local heritage that interweave the archaeologic sites and the different rings that compose their territory. Our approach tries to move away conclusive and dichotomic stances in order to denature categories, destabilize hierarchies, and decenter paradigms. Therefore, we propose an analysis from the myriad of internal process that shows the variability and the mutability in the assemblies of Andinity.},
  author_keywords = {Andean Communities; archaeological sites; Community Museum; heritage; indigeneous identities; intercultural dialogues},
  keywords      = {Andean Communities; archaeological sites; Community Museum; heritage; indigeneous identities; intercultural dialogues},
