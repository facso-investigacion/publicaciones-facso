@article{FACUSEMUOZ2025a,
  author        = {Facuse Muñoz, Marisol Yazmín Ximena},
  title         = {Staging public monuments in Chile: towards an evolving and inclusive approach to heritage},
  year          = {2025},
  journal       = {CULTURE ET MUSEES},
  abstract      = {This article examines iconoclastic and performative interventions on Chilean public statuary during the 2019–2020 social uprising. Drawing on a visual corpus from the digital archive Inventario Iconoclasta de la Insurrección Chilena, it highlights practices of resignification of monuments, ranging from symbolic alteration and bodily appropriation to temporary effacement. The study shows how these ephemeral gestures, amplified by their circulation as images, shift the meaning of monuments, challenge official history, and open the way to an evolving and plural understanding of heritage. By underlining the performative and relational dimension of these stagings, the article proposes to understand heritage not as a fixed entity but as a conflictual process shaped by social and political uses. Thus, monuments become supports for citizen and memorial agency, revealing the need for an inclusive heritage in constant tension with dominant narratives.},
  author_keywords = {Chile; heritage; iconoclasm; public monuments; social uprising},
