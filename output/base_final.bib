}
@article{REYESANDREANI2025,
  author        = {Reyes Andreani, María José},
  title         = {Affective Reconfiguration and Lateral Memories: Antipatriarchal Men's Activisms in Chile},
  year          = {2025},
  journal       = {MITOLOGIAS HOY-REVISTA DE PENSAMIENTO CRITICA Y ESTUDIOS LITERARIOS LATINOAMERICANOS},
  abstract      = {In this article we delve into antipatriarchal men’s collectives in Chile from a qualitative research on gender disputes and social memories. From their narratives, we show how these masculine activisms distance themselves from the logic of redemption and from militant legacies, proposing fragile and huacho bonds, without lineage or promise. In these modes of being-together we trace how the affective embodiment of gender is reconfigured in activism and, in turn, how this is linked to social memories that are lateral to the dominant narratives about the dictatorship.},
