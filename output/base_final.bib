@article{LEIVABAHAMONDES2025,
  author        = {Leiva Bahamondes, Loreto Evelyn},
  title         = {Acceptability, Feasibility, and Health Equity in the Implementation of a Sexuality Education Program: Lessons Learned From a Mixed-Methods Experimental Study},
  year          = {2025},
  journal       = {American Journal of Sexuality Education},
  abstract      = {Sexuality is a critical aspect of adolescent development and is often addressed through school-based sexuality education programs. While comprehensive sexuality education has strong evidence of effectiveness, it often lacks sufficient focus on gender-related issues and mental health, which leads to health inequities. This study evaluates the acceptability, feasibility, preliminary outcomes, and health equity of a comprehensive program. Using a mixed-methods experimental design, 179 students were assigned to control and experimental groups. The intervention was feasible and acceptable, though no significant changes were found in assessments. Case study findings revealed learning outcomes and health equity factors not captured by assessments. Lessons learned are discussed.},
