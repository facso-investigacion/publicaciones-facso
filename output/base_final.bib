@article{TIJOUXMERINO2022b,
  author        = {Tijoux Merino, María Emilia},
  title         = {INTERROGATING THE CONCEPT OF STEREOTYPING AND ITS USE IN SOCIAL SCIENCES IN RELATION TO THE PHENOMENON OF RACISM},
  year          = {2022},
  journal       = {ATENEA},
  abstract      = {Since the beginning of the 20th century and up to the present day, the concept of stereotype has been frequently used in academic studies on racism and discrimination; however, over the course of time its use has opened up to different disciplinary traditions, it has reached different definitions, it has permeated common sense, and in some cases it has been used without deepening on its conceptualization. This obliges us to maintain an attitude of epistemological vigilance against the possibility that the use of the concept of stereotype remains at the level of a spontaneous sociology, it is uncritical or it falls into methodologism. Here we seek to interrogate the concept of stereotype, theoretically, historically and methodologically by reviewing studies carried out at higher education institutions from this concept, through a systematic analysis of articles that work on this problem. Based on this analysis, we critically reflect on the conceptualization of stereotype, the historical conditions in which its form and contents emerge, and the risk of methodologism, to conclude on the relevance of monitoring the use of concepts in order not to reproduce academic racism.},
  author_keywords = {academic racism; epistemological vigilance; racism; stereotypes},
  keywords      = {academic racism; epistemological vigilance; racism; stereotypes},
  doi           = {10.29393/at526-2icto50002},
  issn          = {0718-0462},
  language      = {Español},
