@article{CADENASRAMOS2023,
  author        = {Cadenas Ramos, Hugo Rodrigo},
  title         = {Body and agency in the social systems theory},
  year          = {2023},
  journal       = {REVISTA MAD-REVISTA DEL MAGISTER EN ANALISIS SISTEMICO APLICADO A LA SOCIEDAD},
  abstract      = {This paper addresses the link between body and agency in the context of an underdevelopment of the structure-agency debate in the theory of social systems, particularly in the works of Talcott Parsons and Niklas Luhmann. It highlights how the structure-agency problem emerged in the critique of Parsons' structuralfunctionalism in the 1960s, and how Luhmann sought to overcome this dichotomy by considering society as an autonomous system and humans as its environment. Through his theory of symbolically generalized media, Luhmann demonstrated how social systems motivate the acceptance of their meaningful offers. The paper then seeks a complementation between both theories, specifically regarding Luhmann's symbiotic mechanisms and Parsons' catexis, to explain the acceptance of symbolic offers from society. Emphasis is placed on the interconnection between bodies as systems and social structures, enabling a more comprehensive understanding of motivation and action in social dynamics.},
  author_keywords = {Agency; Body; Cathexis; Social systems theory; Symbolic generalized communication media},
  keywords      = {Agency; Body; Cathexis; Social systems theory; Symbolic generalized communication media},
  doi           = {10.5354/0719-0527.2023.72144},
  issn          = {0718-0527},
  language      = {Español},
  affiliation   = {Trabajo social, 12090120 Departamento de Trabajo Social, Universidad de Chile; Trabajo social, Universidad de Chile},
  document_type = {Article},
  source        = {Scopus},
  note          = {Cited By: 0}
}
