}
@article{JOHNSONMARDONES2025,
  author        = {Johnson Mardones, Daniel Fernando},
  title         = {PRUEBAS INTERNACIONALES, HABILIDADES DEL SIGLO XXI Y NEOLIBERALISMO: Tres contestaciones al campo de políticas globales en el currículum escolar chileno},
  year          = {2025},
  journal       = {Curriculo sem Fronteiras},
  abstract      = {We explore the relationships the Chilean national elementary and secondary education curriculum maintains with international tests and systems of curricular organization by competencies. We reconstruct this relationship by analyzing three key moments of curriculum policies in the post-dictatorship: Curriculum Framework (1996-1998), Progress Maps and Standards (2000-2010), and Curriculum Bases (2011-2020). We resort to intertextuality from Critical Discourse Analysis to investigate the codifications and translations local actors make of the global political field in the prescribed and sustained curriculum. Curriculum policies in this period illustrate a hybrid curriculum architecture, in which a strong tradition of school disciplines coexists with a growing and institutionalized architecture of competencies oriented to the construction of civically cosmopolitan subjects and global workers. We argue that the international testing regime and competency systems for the 21st century have profound normative implications for curriculum deliberation and experiential and value-based pedagogical practice.},
  author_keywords = {competencies; curriculum; globalization; international tests},
  keywords      = {competencies; curriculum; globalization; international tests},
  doi           = {10.35786/1645-1384.v25.2392},
  issn          = {1645-1384},
  language      = {Portugués},
  affiliation   = {Educación, 12090117 Dpto. Educación (funcionamiento), Universidad de Chile},
  document_type = {Article},
  source        = {Scopus},
  note          = {Cited By: 0}
}
@article{FERNNDEZDROGUETT2024a,
  author        = {Fernández Droguett, Roberto Andrés},
  title         = {Psychopharmaceuticals and neoliberalism: analysis of the multimodal discourse of advertising posters in psychiatry congresses in Chile},
  year          = {2024},
  journal       = {Latin-American Journal of Discourse Studies},
  abstract      = {This article addresses the expansion of the pharmaceutical market and the technologies associated with the production of health in contemporary society. From a qualitative approach and based on multimodal discourse analysis, advertising posters for psychoactive drugs at psychiatry congresses in Chile (2010-2014) are examined. The results show that pharmaceutical products are configured around a power relationship that moves away from the disease discourse and from the regulatory ideals of optimization and functionality. In accordance with this productive conception of power and the configuration of government technologies under neoliberalism, the emergence of psycho pharmaceuticals as a device is proposed. This notion is based on an articulation of the self in the form of a company based on the sphere of consumption. It is concluded that in the discursive level psychopharmaceuticals imply an intensification of neoliberal logic in the field of subjectivity.},
  author_keywords = {Chile; Multimodal discourse analysis; Neoliberalism; Pharmaceutical advertising; Psychoactive drugs},
  keywords      = {Chile; Multimodal discourse analysis; Neoliberalism; Pharmaceutical advertising; Psychoactive drugs},
