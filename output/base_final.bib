  language      = {Inglés},
  affiliation   = {Psicología, 12090118 Dpto. de  Psicología (funcionamiento), Universidad de Chile},
  document_type = {Article},
  source        = {Scopus},
  note          = {Cited By: 2}
}
@article{LABORDAROJAS2022c,
  author        = {Laborda Rojas, Mario Arturo},
  title         = {Extinction Contexts do not work as Conditioned Inhibitors in an Appetitive Task,Contexto de Extinción no actúa como Inhibidor Condicionado en una Tarea Apetitiva},
  year          = {2022},
  journal       = {Revista Argentina de Ciencias del Comportamiento},
  abstract      = {To explain Pavlovian extinction, it has been proposed that the extinction context acts as a conditioned inhibitor, contributing to relapses. Two experiments using rats in an appetitive conditioning task evaluated the inhibitory potential of the extinction context and its retrospective revaluation. In Experiment 1, subjects learned an association in Context A, that was then extinguished in Context B. Subsequently, the exciter was extinguished in a third context to reevaluate the inhibitory potential of Context B. Finally, summation and retardation tests were carried to measure the inhibition of Context B. Experiment 2 increased the number of Acquisition and Extinction trials to strengthen inhibitory training. Results of both experiments show that the extinction context did not act as a conditioned inhibitor. Our data contrasts with findings in aversive conditioning.},
  author_keywords = {conditioned inhibition; conditioning; extinction; retrospective revaluation},
  keywords      = {conditioned inhibition; conditioning; extinction; retrospective revaluation},
  doi           = {10.32348/1852.4206.V14.N3.27994},
  issn          = {1852-4206},
  language      = {Español},
  affiliation   = {Psicología, Universidad de Chile},
  document_type = {Article},
  source        = {Scopus},
  note          = {Cited By: 0}
}
@article{QUEZADASCHOLZ2025b,
  author        = {Quezada Scholz, Vanetza Estela and Bórquez Quintas, Margarita María Doralisa},
  title         = {Fear conditioning of the ocular response in a picture-picture paradigm},
  year          = {2025},
  journal       = {REVISTA ARGENTINA DE CIENCIAS DEL COMPORTAMIENTO},
  abstract      = {Fear conditioning of the ocular response in a picture-picture paradigm. This study validates a model of fear conditioning by recording the Ocular Response (OR) in an image-image paradigm. Thirty-four individuals completed the acquisition, extinction, and testing phases, where the response to conditioned (CS) and unconditioned stimuli (US) was measured using the OR (fixation time, number of fixations, fixation latency) and the expectation of occurrence of the US. The results show differential learning in acquiring fixation latency and the expectation of US occurrence. Extinction was only observed in the latter measure. There was an increase in the number of fixations to aversive images. The ocular response is a valid and promising method to assess fear learning, allowing to address attentional biases and avoidance, characteristics of anxiety-related disorders. The present study provides a rigorous methodological basis for future research.},
  author_keywords = {conditioning; fear learning; ocular response; translational research},
