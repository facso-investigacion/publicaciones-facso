@incollection{MIRANDAFUENZALIDA2025a,
  author        = {Miranda Fuenzalida, Daniel Andrés},
  title         = {Schools, citizenship education, and democratic dispositions among European youth: A comparative analysis using ICCS 2016 data},
  year          = {2025},
  booktitle     = {Research Handbook on Education and Democracy},
  abstract      = {Building on theories of political socialization and educational effectiveness and utilizing data from the 2016 International Civic and Citizenship Education Study (ICCS), this chapter examines the potential of different citizenship education teaching and learning approaches to promote a wide range of democratic dispositions (i.e., cognitive, affective, behavioral) among adolescents. The aim of the research is twofold. First, evidence is provided regarding school differences in terms of their students’ democratic dispositions. Second, an account is given of the relationship between various citizenship education teaching and learning approaches and the democratic dispositions of youth. A comparative stance is taken to illustrate differences driven by the type of democratic disposition and the context of the European educational system under study. Our results indicate substantial variation in cognitive democratic dispositions across schools in different European educational systems. In contrast, affective and behavioral democratic dispositions generally exhibit smaller variations attributable to schools and more varied patterns. Additionally, our findings reveal several key patterns in the relationship between school factors and students’ democratic dispositions. This chapter aims to contribute a critical and empirical quantitative analysis to debates regarding the role of citizenship education in developing a wide range of democratic dispositions among youth.},
  author_keywords = {Citizenship education; Comparative study; Democratic dispositions; European educational systems; ICCS 2016; International Civic and Citizenship Education Study; Lower-secondary education},
  keywords      = {Citizenship education; Comparative study; Democratic dispositions; European educational systems; ICCS 2016; International Civic and Citizenship Education Study; Lower-secondary education},
  doi           = {10.4337/9781803928111.00025},
  issn          = {180392811},
  affiliation   = {Psicología, 12090118 Dpto. de  Psicología (funcionamiento), Universidad de Chile; Psicología, Universidad de Chile},
  document_type = {Book Chapter},
  source        = {Scopus},
  note          = {Cited By: 0}
}
@incollection{MIRANDAFUENZALIDA2025b,
  author        = {Miranda Fuenzalida, Daniel Andrés},
  title         = {Civic education as a tool to mitigate social inequalities in civic outcomes: A literature review},
  year          = {2025},
  booktitle     = {Research Handbook on Education and Democracy},
  abstract      = {The outcomes of young people’s civic attitudes, beliefs, knowledge, or political behaviour, show a series of gaps linked to family origin (e.g. socioeconomic background) and characteristics of the students (e.g. gender). These differences constitute a threat to the legitimacy of democracy since some people participate more or are better prepared than others to exercise their role as citizens. Likewise, education for citizenship at school is considered a relevant source for acquiring political orientations, potentially influencing the gaps of origin. This chapter evaluates citizenship education’s role in shaping these inequalities in civic outcomes, distinguishing between compensation, acceleration, and maintenance effects. For this, a literature review was carried out to identify, evaluate, and synthesize the main findings around this objective. The review indicates that the evidence favouring the compensation hypothesis is prominent. Aligned with previous literature, working-class students benefit more from civic education activities than middle-class students. In contrast, the evidence also shows a substantial maintenance effect and, to a lesser extent, acceleration effects. The chapter aims to contribute to the debate on citizenship education and its role in promoting political equality.},
  author_keywords = {Acceleration effect of civic education; Citizenship education; Mitigation; Youth citizenship inequalities},
  keywords      = {Acceleration effect of civic education; Citizenship education; Mitigation; Youth citizenship inequalities},
  doi           = {10.4337/9781803928111.00027},
  issn          = {180392811},
  affiliation   = {Psicología, 12090118 Dpto. de  Psicología (funcionamiento), Universidad de Chile; Psicología, Universidad de Chile},
  document_type = {Book Chapter},
  source        = {Scopus},
  note          = {Cited By: 0}
}
@article{ANIGSTEIN2020a,
  author        = {Anigstein ., María Sol},
  title         = {Implications of public purchases from family farming: Reflections on the chilean case},
  year          = {2020},
  journal       = {AGER-REVISTA DE ESTUDIOS SOBRE DESPOBLACION Y DESARROLLO RURAL},
  abstract      = {Government purchases of food from family farmers aim to provide a new market for smallscale farming while promoting food security for vulnerable populations. In Latin America there are various examples of these initiatives but with important differences in their implementation. Our objective is to review the effects on the farmers who sell into these programs, considering the case of Chile. There, since 2017, companies hired by the government to provide school meals are required to include a percentage of local products in their purchases. Information was collected through personal interviews with farmers and advisors from three agricultural organizations participating in government purchases in two different regions. The results show that in this case public purchases have the novelty of being a formal market for farmers, which is a very relevant experience for them. However, the conditions are neither stable nor always beneficial for farmers due to important asymmetries in negotiating power with purchasing companies. We conclude that the Chilean initiative has interesting potential impacts, but some major changes must be made to it, as greater involvement and will on the part of the parties.},
  author_keywords = {Chile; Family farmers; Inclusive markets; Public procurements; School meals},
  keywords      = {Chile; Family farmers; Inclusive markets; Public procurements; School meals},
  doi           = {10.4422/ager.2020.05},
