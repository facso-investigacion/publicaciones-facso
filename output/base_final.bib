@incollection{MUOZARCE2025c,
  author        = {Muñoz Arce, Gianinna Inés},
  title         = {Decolonial Perspectives for Epistemic Justice},
  year          = {2025},
  booktitle     = {The Routledge Handbook of Social Work and Migration},
  abstract      = {In recent years, a notable interest in the discussion of decolonial perspectives has emerged from some progressive sectors of social work at a global scale. However, there are also re-emerging some essentialist and reductionist conceptions of what “decolonise” social work, and particularly, social work research, could mean. Agreeing with the relevance of decolonial perspectives for the development of social work nowadays, in this chapter, I want to discuss what “decolonising” social work research implies if appraised from Latin American decolonial thought. The concepts of coloniality, geopolitics of knowledge and epistemic injustice are analysed to assert, from these standpoints, that decolonising social work research is not just a matter of will: it has ethical, epistemic and practical requirements. From these understandings, we can drive “decolonial gestures” at macro, mezzo and micro scales to dismantle the mechanisms that reproduce injustice in social work knowledge. This is a relevant debate in today's world, where diversity and dissident identities manifest themselves in heterogeneous ways, challenging the content, manner and purpose in which knowledge is produced and disseminated.},
  doi           = {10.4324/9781032692272-29},
  affiliation   = {Trabajo social, Universidad de Chile},
  document_type = {Book Chapter},
  source        = {Scopus},
  note          = {Cited By: 0}
