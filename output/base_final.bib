@incollection{CASTILLOVALENZUELA2025c,
  author        = {Castillo Valenzuela, Juan Carlos},
  title         = {THE IDEOLOGICAL UNDERPINNINGS OF DISTRIBUTIVE UNFAIRNESS EVALUATIONS: Evidence from Latin America Between 1997 and 2020},
  year          = {2025},
  booktitle     = {The Political Psychology of Social Unrest in Latin America},
  abstract      = {Economic inequality has an impact on how people think, feel and behave in social contexts. Research has investigated the pernicious effects of economic inequality with a special emphasis on wealthy regions, overlooking the unique challenges faced by places with longstanding inequalities, such as Latin America (LA). In our chapter, we aim to evaluate the effects of economic inequality on distributive justice evaluations from 1997 to 2020 and examine how they vary due to individual, contextual, and ideological factors. We used 13 waves from 18 Latin American countries over 23 years (more than 250, 000 participants) and performed multilevel regression analyses for comparative longitudinal surveys. We found that, on average, people believe income distribution is very unfair in their countries, and such an evaluation has not changed meaningfully over the years. Still, we also found differences between countries, suggesting that this depends on the country’s history and development. Furthermore, we found that people evaluate income distribution more unfairly when they think they cannot move up the social ladder, oppose neoliberal ideas, and expect a worse economic situation for their country. Thus, we argue that ideological factors shape distributive unfairness evaluations beyond structural (e.g., economic inequality) and situational (e.g., socioeconomic status) variables.},
  doi           = {10.4324/9781003282174-2},
  issn          = {104030650},
  affiliation   = {Sociología, 12090119 Dpto. de Sociología (funcionamiento), Universidad de Chile},
  document_type = {Book Chapter},
  source        = {Scopus},
  note          = {Cited By: 3}
}
@incollection{CASTILLOVALENZUELA2025d,
  author        = {Castillo Valenzuela, Juan Carlos and Miranda Fuenzalida, Daniel Andrés},
  title         = {THE POLITICAL PARTICIPATION OF LATIN AMERICAN SCHOOL-AGE STUDENTS: Resources, Political Attitudes and Civic Learning Opportunities},
  year          = {2025},
  booktitle     = {The Political Psychology of Social Unrest in Latin America},
  abstract      = {This chapter examines the political participation of youth in four Latin American countries: Chile, Colombia, Mexico and the Dominican Republic. The study aims to describe the levels of youth involvement in different types of participation, as well as to characterise the extent to which resources, political attitudes, and school opportunities to learn civic skills are linked to different types of involvement in various forms of political participation and the factors influencing this engagement. The study utilises data from the International Civic and Citizenship Education Study (ICCS) conducted in 2009 and 2016. The ICCS data provides insights into students’ civic dispositions, socio-economic backgrounds, political attitudes and civic learning opportunities at school. The study employs a comparative analysis of youth political participation across the four countries, examining the relationship between socio-economic resources, political attitudes and civic education opportunities, and their impact on students’ willingness to engage in various forms of political activities. The findings indicate a significant increase in youth participation in non-traditional political activities, particularly protests, across Latin America. This trend reflects a broader global pattern of youth activism. The study highlights the importance of socio-economic resources, political attitudes and educational opportunities in shaping youth political engagement.},
  doi           = {10.4324/9781003282174-6},
  issn          = {104030650},
  affiliation   = {Sociología, 12090119 Dpto. de Sociología (funcionamiento), Universidad de Chile; Psicología, 12090118 Dpto. de  Psicología (funcionamiento), Universidad de Chile},
  document_type = {Book Chapter},
