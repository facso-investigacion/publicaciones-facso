}
@article{GISSIBARBIERI2025,
  author        = {Gissi Barbieri, Emiliano Nicolás},
  title         = {Migración venezolana en Colombia: una revisión crítica de la literatura},
  year          = {2025},
  journal       = {REMHU: Revista Interdisciplinar da Mobilidade Humana},
  abstract      = {In the last decade, academia in Colombia, as a key player in understanding migratory phenomena, has focused much of its interest on analyzing the Venezuelan diaspora. This article critically categorizes and analyzes the scientific production on Venezuelan migration in Colombia, generated between 2018 and 2024, through the ultramodern review method. The results show that research on the subject has focused on the analysis of migration dynamics, demographic studies, and the impact of migration in the economic sphere. Finally, it is noted that the theoretical approach has been limited, leaning more towards explaining migration from economic models. Studies with participatory methodologies and evaluations of the impact of measures implemented by the national government are also scarce, which would be a significant contribution to the construction of public policy.},
